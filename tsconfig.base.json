{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@weather-app/shared-ui": ["libs/shared/ui/src/index.ts"],
      "@weather-app/weather-features": ["libs/weather/features/src/index.ts"],
      "@weather-app/astronomy-features": [
        "libs/astronomy/features/src/index.ts"
      ],
      "@weather-app/timezone-features": ["libs/timezone/features/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
